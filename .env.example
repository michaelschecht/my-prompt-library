# Prompt Library Configuration

# ============================================
# GitHub Mode (Remote Storage)
# ============================================
# Set USE_GITHUB_MODE=true to fetch prompts from GitHub repository
# Set USE_GITHUB_MODE=false to use local filesystem (default for development)

USE_GITHUB_MODE=false

# Required when USE_GITHUB_MODE=true:
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_repo_name
GITHUB_BRANCH=main

# ============================================
# Quick Toggle Guide
# ============================================
# 
# LOCAL MODE (for development):
#   USE_GITHUB_MODE=false
#   - Reads from local prompts/ directory
#   - Faster, no API calls
#   - No rate limits
#
# GITHUB MODE (for production/deployment):
#   USE_GITHUB_MODE=true
#   - Fetches from GitHub repository
#   - Batched API calls (50 at a time)
#   - 5-minute cache to reduce API usage
#   - Requires valid GITHUB_TOKEN
