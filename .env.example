# Environment Variables Template
# Copy this file to .env and fill in your values
# Never commit .env to git!

# Gemini API Key (optional, for AI features)
# Get your key at: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# Node Environment
NODE_ENV=development

# GitHub (required in Vercel/prod for write operations like Copy to My Prompts)
# Token should have repo contents write permissions.
GITHUB_TOKEN=your-github-token-here
GITHUB_OWNER=your-github-username-or-org
GITHUB_REPO=my-prompt-library
GITHUB_BRANCH=mike_desktop
